# 로컬 에이전트/도구 상태 (커밋 안 함)
.omc/

# Obsidian 로컬 작업공간 상태 (머신별)
.obsidian/workspace.json

# JetBrains IDE 로컬 설정
.idea/

# Python 가상환경 (tools/ 스크립트용)
.venv/
__pycache__/

# 관계 그래프 파생물 — graph.html(텍스트)은 커밋, graph.sqlite(바이너리)는 제외.
# graph.sqlite는 tools/build_graph.py가 생성하며 graph_query.py가 없으면 즉석 빌드한다.
graph.sqlite

# Quartz (정적 사이트 생성기)
node_modules/
public/
.quartz-cache/
# 주의: content/ 는 .gitignore에 넣지 않는다. Quartz가 .gitignore를 존중해
# staged content를 통째로 무시하기 때문. 대신 .git/info/exclude 로 로컬 추적만 제외한다.

